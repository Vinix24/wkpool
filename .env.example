# Copy to .env and fill in. Everything is optional — without a key the
# news/injury feature is skipped and the model runs on public data only.
PERPLEXITY_API_KEY=

# Optional: mail PREDICTIONS.md to yourself after each daily run
MAIL_TO=
SMTP_USER=
SMTP_PASS=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# Optional: faster World Cup results feed (closes the martj42 lag)
FOOTBALL_DATA_API_KEY=
# Optional: bookmaker outright odds for the (off-by-default) odds plugin
ODDS_API_KEY=
